{
  "name": "sloth-cc",
  "version": "0.2.6",
  "description": "A Claude Code-like CLI programming assistant with multi-model support (GLM, DeepSeek, Qwen, Doubao, etc.)",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "sloth": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "cli",
    "ai",
    "coding-assistant",
    "llm",
    "glm",
    "deepseek",
    "qwen",
    "chatgpt"
  ],
  "author": "zhangliuyang1",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zhangliuyang1/sloth.git"
  },
  "bugs": {
    "url": "https://github.com/zhangliuyang1/sloth/issues"
  },
  "homepage": "https://github.com/zhangliuyang1/sloth#readme",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "ink": "^5.0.1",
    "react": "^18.3.1",
    "@anthropic-ai/sdk": "^0.39.0",
    "openai": "^4.91.0",
    "chalk": "^5.3.0",
    "fast-glob": "^3.3.2",
    "marked": "^15.0.7",
    "marked-terminal": "^7.3.0",
    "zod": "^3.24.3",
    "tiktoken": "^1.0.19",
    "diff": "^7.0.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "nanoid": "^5.1.5",
    "dotenv": "^16.4.7"
  },
  "devDependencies": {
    "vitest": "^3.1.2",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3",
    "@types/react": "^18.3.1",
    "@types/node": "^22.15.3",
    "@types/diff": "^7.0.2"
  }
}
